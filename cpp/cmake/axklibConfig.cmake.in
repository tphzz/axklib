@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(nlohmann_json CONFIG)
find_dependency(utf8cpp CONFIG)

set(_axklib_needs_audio FALSE)
if(NOT axklib_FIND_COMPONENTS OR "audio" IN_LIST axklib_FIND_COMPONENTS OR "c" IN_LIST axklib_FIND_COMPONENTS)
  set(_axklib_needs_audio TRUE)
endif()
if(_axklib_needs_audio)
  find_dependency(SndFile CONFIG)
  set(_axklib_saved_module_path "${CMAKE_MODULE_PATH}")
  list(PREPEND CMAKE_MODULE_PATH "${CMAKE_CURRENT_LIST_DIR}")
  find_dependency(SOXR)
  set(CMAKE_MODULE_PATH "${_axklib_saved_module_path}")
  unset(_axklib_saved_module_path)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/axklibTargets.cmake")

set(axklib_core_FOUND TRUE)
set(axklib_audio_FOUND TRUE)
set(axklib_c_FOUND TRUE)

check_required_components(axklib)
