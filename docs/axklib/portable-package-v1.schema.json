{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tphzz.github.io/axklib/axklib/portable-package-v1.schema.json",
  "title": "axklib portable-package manifest 1.0",
  "description": "Syntactic schema for manifest.json in an axklib portable-package archive. Canonical ordering, identities, closure, relocation bindings, and archive rules are additional normative constraints.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "objects",
    "package_id",
    "package_kind",
    "payloads",
    "provenance",
    "relationships",
    "roots",
    "schema_version"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "package_kind": {
      "enum": [
        "volume",
        "program",
        "sbac",
        "sbnk",
        "smpl",
        "sequence",
        "bundle"
      ]
    },
    "package_id": {
      "$ref": "#/$defs/sha256"
    },
    "roots": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/root"
      }
    },
    "objects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/object"
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/relationship"
      }
    },
    "payloads": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/payload"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_media_kind"
      ],
      "properties": {
        "source_media_kind": {
          "enum": [
            "sfs",
            "fat12-floppy",
            "iso9660",
            "standalone-object"
          ]
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "nodeId": {
      "type": "string",
      "pattern": "^n-[0-9a-f]{64}$"
    },
    "edgeId": {
      "type": "string",
      "pattern": "^e-[0-9a-f]{64}$"
    },
    "root": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name",
        "kind",
        "node_ids"
      ],
      "properties": {
        "display_name": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "volume",
            "prog",
            "sbac",
            "sbnk",
            "smpl",
            "sequ"
          ]
        },
        "node_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nodeId"
          }
        }
      }
    },
    "placementHint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "category_name",
        "entry_name",
        "group_name",
        "volume_name"
      ],
      "properties": {
        "category_name": {
          "type": "string"
        },
        "entry_name": {
          "type": "string"
        },
        "group_name": {
          "type": "string"
        },
        "volume_name": {
          "type": "string"
        }
      }
    },
    "relocation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_ids",
        "expected_hex",
        "mask_hex",
        "offset",
        "role",
        "width"
      ],
      "properties": {
        "edge_ids": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/edgeId"
          }
        },
        "expected_hex": {
          "type": "string",
          "pattern": "^[0-9a-f]*$"
        },
        "mask_hex": {
          "type": "string",
          "pattern": "^[0-9a-f]*$"
        },
        "offset": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        "role": {
          "enum": [
            "SMPL_GROUP_ID",
            "SMPL_REFERENCE_VALUE",
            "SBNK_LEFT_MEMBER_CACHED_REFERENCE",
            "SBNK_RIGHT_MEMBER_CACHED_REFERENCE",
            "SBNK_GROUP_MEMBERSHIP",
            "SBNK_PROGRAM_BITMAP",
            "SBAC_SLOT_HANDLE",
            "PROG_ASSIGNMENT_HANDLE"
          ]
        },
        "width": {
          "type": "integer",
          "minimum": 1,
          "maximum": 4294967295
        }
      }
    },
    "object": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "audio_sha256",
        "name",
        "node_id",
        "normalized_sha256",
        "object_format",
        "object_type",
        "payload_path",
        "payload_sha256",
        "placement_hint",
        "relocations",
        "semantic_sha256"
      ],
      "properties": {
        "audio_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string"
        },
        "node_id": {
          "$ref": "#/$defs/nodeId"
        },
        "normalized_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "object_format": {
          "enum": [
            "current",
            "alternating-byte",
            "unknown"
          ]
        },
        "object_type": {
          "enum": [
            "SMPL",
            "SBNK",
            "SBAC",
            "PROG",
            "SEQU",
            "PRF3"
          ]
        },
        "payload_path": {
          "type": "string",
          "pattern": "^payloads/sha256/[0-9a-f]{64}\\.bin$"
        },
        "payload_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "placement_hint": {
          "$ref": "#/$defs/placementHint"
        },
        "relocations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relocation"
          }
        },
        "semantic_sha256": {
          "oneOf": [
            {
              "$ref": "#/$defs/sha256"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "relationship": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "edge_id",
        "ordinal",
        "role",
        "source_node_id",
        "target_node_id"
      ],
      "properties": {
        "edge_id": {
          "$ref": "#/$defs/edgeId"
        },
        "ordinal": {
          "type": "integer",
          "minimum": 0,
          "maximum": 4294967295
        },
        "role": {
          "enum": [
            "PROG_ASSIGNMENT_TO_SBAC",
            "PROG_ASSIGNMENT_TO_SBNK",
            "SBAC_SLOT_TO_SBNK",
            "SBNK_LEFT_MEMBER_TO_SMPL",
            "SBNK_RIGHT_MEMBER_TO_SMPL"
          ]
        },
        "source_node_id": {
          "$ref": "#/$defs/nodeId"
        },
        "target_node_id": {
          "$ref": "#/$defs/nodeId"
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "media_type",
        "path",
        "sha256",
        "size_bytes"
      ],
      "properties": {
        "media_type": {
          "const": "application/vnd.axklib.yamaha-object"
        },
        "path": {
          "type": "string",
          "pattern": "^payloads/sha256/[0-9a-f]{64}\\.bin$"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
