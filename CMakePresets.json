{
  "version": 7,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 28,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/native/${presetName}",
      "toolchainFile": "${sourceDir}/external/vcpkg/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "AXK_BUILD_CLI": "ON",
        "AXK_WARNINGS_AS_ERRORS": "ON",
        "BUILD_TESTING": "ON"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "displayName": "Native Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Native Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "asan",
      "inherits": "debug",
      "displayName": "Native ASan and UBSan",
      "cacheVariables": {
        "AXK_ENABLE_SANITIZERS": "ON"
      }
    },
    {
      "name": "coverage",
      "inherits": "debug",
      "displayName": "Native Coverage",
      "cacheVariables": {
        "AXK_ENABLE_COVERAGE": "ON",
        "AXK_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "tsan",
      "inherits": "debug",
      "displayName": "Native ThreadSanitizer",
      "cacheVariables": {
        "AXK_ENABLE_THREAD_SANITIZER": "ON"
      }
    },
    {
      "name": "clang-tidy",
      "inherits": "debug",
      "displayName": "Native Clang-Tidy",
      "cacheVariables": {
        "CMAKE_CXX_CLANG_TIDY": "clang-tidy",
        "AXK_WARNINGS_AS_ERRORS": "OFF"
      }
    },
    {
      "name": "fuzz-local",
      "inherits": "debug",
      "displayName": "Local libFuzzer smoke",
      "cacheVariables": {
        "AXK_BUILD_FUZZERS": "ON",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "asan",
      "configurePreset": "asan"
    },
    {
      "name": "coverage",
      "configurePreset": "coverage"
    },
    {
      "name": "tsan",
      "configurePreset": "tsan"
    },
    {
      "name": "clang-tidy",
      "configurePreset": "clang-tidy"
    },
    {
      "name": "fuzz-local",
      "configurePreset": "fuzz-local",
      "targets": ["fuzz-local"]
    }
  ],
  "testPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "asan",
      "configurePreset": "asan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "coverage",
      "configurePreset": "coverage",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
