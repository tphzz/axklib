{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tphzz.github.io/axklib/schemas/semantic-contracts-2.0.json",
  "title": "axklib language-neutral semantic contracts",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "contracts"],
  "properties": {
    "schema_version": {"const": "2.0"},
    "contracts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "input_path",
          "input_sha256",
          "operation",
          "expected_semantic_sha256",
          "verification_class"
        ],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "input_path": {"type": "string", "minLength": 1},
          "input_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "operation": {"type": "string", "minLength": 1},
          "expected_semantic_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
          "verification_class": {
            "enum": ["verified", "corroborated", "tentative", "unknown"]
          }
        }
      }
    }
  }
}
