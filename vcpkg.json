{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "axklib",
  "builtin-baseline": "f87344cac03158cbf1467264565f1fd36b382a24",
  "dependencies": [
    "fatfs",
    {
      "name": "libsndfile",
      "default-features": false,
      "features": [
        "external-libs"
      ]
    },
    "nlohmann-json",
    "soxr",
    "utfcpp"
  ],
  "features": {
    "application": {
      "description": "Dependencies used only by the internal application service",
      "dependencies": [
        "hash-library"
      ]
    },
    "cli": {
      "description": "Dependencies used only by the standalone axklib CLI",
      "dependencies": [
        "cli11"
      ]
    },
    "server": {
      "description": "Dependencies used only by the Crow REST and WebSocket server",
      "dependencies": [
        "crow",
        "json-schema-validator"
      ]
    },
    "tests": {
      "description": "Dependencies used only by native test targets",
      "dependencies": [
        "gtest"
      ]
    }
  }
}
