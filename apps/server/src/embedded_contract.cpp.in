#include "axklib/server/server.hpp"

namespace {

constexpr unsigned char openapi_document[] = {
@AXK_SERVER_OPENAPI_BYTES@    0x00,
};

} // namespace

std::string_view axk::server::embedded_openapi() noexcept {
    return {reinterpret_cast<const char *>(openapi_document), @AXK_SERVER_OPENAPI_SIZE@U};
}
