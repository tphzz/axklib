{
  "name": "axkdeck",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=22.12"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm contract:check && svelte-check --tsconfig ./tsconfig.app.json && vite build",
    "contract:check": "node tools/openapi-contract.mjs check",
    "contract:generate": "node tools/openapi-contract.mjs write",
    "version:check": "node tools/check-versions.mjs",
    "format": "prettier --write \"src/**/*.{ts,svelte}\" vite.config.ts",
    "format:check": "prettier --check \"src/**/*.{ts,svelte}\" vite.config.ts",
    "test": "vitest run",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.app.json --watch",
    "desktop:dev": "tauri dev",
    "desktop:dev:fresh": "cmake --build ../../build/native/release --target axklib_server && tauri dev",
    "desktop:build": "tauri build",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-log": "2.9.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tailwindcss/vite": "4.3.2",
    "@tauri-apps/cli": "2.11.4",
    "@testing-library/svelte": "5.4.2",
    "@types/node": "24.13.3",
    "svelte": "5.56.4",
    "svelte-check": "4.7.2",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vite": "8.1.4",
    "vitest": "4.1.9",
    "jsdom": "29.1.1",
    "openapi-typescript": "7.13.0",
    "prettier": "3.9.5",
    "prettier-plugin-svelte": "4.1.1"
  }
}
